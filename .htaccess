RewriteEngine On
RewriteBase /

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Remove trailing slash (except root)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ /$1 [L,R=301]

# If the request is for an existing file or directory, serve it
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Route clean article URLs (e.g. /507171-article-slug) to artikel.html
# This is an internal rewrite — returns HTTP 200, not 404
RewriteRule ^(.+)$ /artikel.html [L,QSA]

# Fallback: if mod_rewrite doesn't work, serve artikel.html as custom 404 page (HTTP 200 via PHP)
ErrorDocument 404 /artikel.html
